# ============================================
# BLOODLINE - Environment Variables Configuration
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
# MongoDB Connection URI (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bloodline

# JWT Configuration
# JWT Secret (Required - Use a strong, random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration (Required)
# Gmail credentials for sending OTP and notifications
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# CORS Configuration
# Frontend URL(s) - Comma-separated for multiple origins
# Examples:
# CORS_ORIGIN=https://your-app.onrender.com
# CORS_ORIGIN=https://your-app.onrender.com,https://localhost:3000
CORS_ORIGIN=https://your-frontend-app.onrender.com

# Frontend URL for email links and redirects
FRONTEND_URL=https://your-frontend-app.onrender.com

# ============================================
# DEVELOPMENT NOTES:
# ============================================
# 1. Copy this file to .env and fill in actual values
# 2. Never commit .env file to version control
# 3. Use strong, unique passwords and secrets
# 4. For Gmail, generate an App Password instead of using your main password
# 5. MongoDB Atlas provides free tier for development
# 6. Render automatically sets these environment variables in production
# ============================================
